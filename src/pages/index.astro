    <div class="sec-kicker">Contact</div>
    <h2>Talk to us.</h2>
    <p>General queries and product support: <a href="mailto:support@nevarrotech.com">support@nevarrotech.com</a><br>
    Enterprise engagements: <a href="mailto:adithya@gmail.com">adithya@gmail.com</a></p>
  </section>
