<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Nevarro Technologies</title>
<meta name="description" content="Nevarro Technologies — a boutique software consulting and micro-SaaS studio. Building software for the 22nd century.">
<style>
  :root{
    --bg:#fbfbfd; --text:#1d1d1f; --muted:#6e6e73; --faint:#a1a1a6;
    --hairline:#e8e8ed; --accent-a:#5e8bff; --accent-b:#b06bff; --coral:#ff6f61;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%}
  body{
    background:var(--bg); color:var(--text);
    font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","SF Pro Text","Helvetica Neue",Inter,Arial,sans-serif;
    -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;
    display:flex;flex-direction:column;min-height:100vh;overflow-x:hidden;
  }
  nav{display:flex;align-items:center;justify-content:space-between;padding:1.4rem clamp(1.5rem,5vw,4rem)}
  .wordmark{font-size:.95rem;font-weight:600;letter-spacing:.14em}
  nav a{font-size:.85rem;color:var(--muted);text-decoration:none;transition:color .25s ease}
  nav a:hover{color:var(--text)}
  main{position:relative;flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:4rem 1.5rem 5rem}
  h1{font-size:clamp(2.6rem,7.5vw,5.2rem);font-weight:700;letter-spacing:-.025em;line-height:1.05;max-width:16ch}
  h1 .grad{background:linear-gradient(92deg,var(--accent-a),var(--accent-b));-webkit-background-clip:text;background-clip:text;color:transparent}
  .sub{margin-top:1.5rem;font-size:clamp(1.05rem,2.3vw,1.3rem);font-weight:400;color:var(--muted);letter-spacing:-.01em;max-width:44ch;line-height:1.6}
  .support{margin-top:1.1rem;font-size:clamp(.95rem,2vw,1.05rem);color:var(--muted)}
  .support a{color:var(--accent-a);text-decoration:none;font-weight:500;transition:opacity .25s ease}
  .support a:hover{opacity:.7}

  /* NEV */
  .stage{margin-top:4rem;width:min(260px,60vw)}
  .stage svg{width:100%;height:auto;overflow:visible}
  .bot{animation:bob 4.5s ease-in-out infinite}
  @keyframes bob{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
  .shadow{transform-origin:150px 262px;animation:shadowbob 4.5s ease-in-out infinite}
  @keyframes shadowbob{0%,100%{transform:scaleX(1);opacity:.16}50%{transform:scaleX(.82);opacity:.09}}
  .eyes{transform-origin:150px 128px;animation:blink 5.2s ease-in-out infinite}
  @keyframes blink{0%,46%,50%,100%{transform:scaleY(1)}48%{transform:scaleY(.06)}}
  .arm-r{transform-origin:206px 168px;animation:wave 7s ease-in-out infinite}
  @keyframes wave{0%,78%,100%{transform:rotate(0)}84%{transform:rotate(-42deg)}90%{transform:rotate(-14deg)}95%{transform:rotate(-38deg)}}
  .ant-light{animation:antpulse 3s ease-in-out infinite}
  @keyframes antpulse{0%,100%{opacity:1}50%{opacity:.4}}

  /* moon scene */
  .moon-scene{position:absolute;top:clamp(.5rem,4vh,3rem);right:clamp(1rem,7vw,6rem);width:min(170px,26vw);pointer-events:none}
  .moon-scene svg{width:100%;height:auto;overflow:visible}
  .orbit{transform-origin:85px 85px;animation:orbit 16s linear infinite}
  .orbit-counter{transform-origin:85px 14px;animation:orbitcounter 16s linear infinite}
  @keyframes orbit{to{transform:rotate(360deg)}}
  @keyframes orbitcounter{from{transform:rotate(0)}to{transform:rotate(-360deg)}}
  .luna-eyes{transform-origin:85px 12px;animation:blink 6.4s ease-in-out infinite}

  /* footer + PIP */
  footer{position:relative;border-top:1px solid var(--hairline);display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;font-size:.78rem;color:var(--faint);padding:1.3rem clamp(1.5rem,5vw,4rem)}
  footer a{color:var(--muted);text-decoration:none;transition:color .25s}
  footer a:hover{color:var(--text)}
  .perch{position:absolute;top:-46px;right:clamp(2rem,12vw,9rem);width:56px;pointer-events:none}
  .perch svg{width:100%;height:auto;overflow:visible}
  .perch-eyes{transform-origin:28px 24px;animation:blink 4.6s ease-in-out infinite;animation-delay:1.2s}
  .leg-l{transform-origin:20px 40px;animation:kick 3.4s ease-in-out infinite}
  .leg-r{transform-origin:36px 40px;animation:kick 3.4s ease-in-out infinite;animation-delay:.4s}
  @keyframes kick{0%,60%,100%{transform:rotate(0)}75%{transform:rotate(14deg)}}

  @media (max-width:700px){
    .moon-scene{width:110px;right:.75rem;top:.25rem;opacity:.9}
    footer{justify-content:center;text-align:center}
    .perch{right:1.5rem}
  }
  @media (prefers-reduced-motion: reduce){
    .bot,.shadow,.eyes,.arm-r,.ant-light,.orbit,.orbit-counter,.luna-eyes,.perch-eyes,.leg-l,.leg-r{animation:none}
  }
</style>
</head>
<body>

<nav>
  <span class="wordmark">NEVARRO</span>
  <a href="mailto:support@nevarrotech.com">Support</a>
</nav>

<main>
  <!-- LUNA — orbiting the moon, top right -->
  <div class="moon-scene" aria-hidden="true">
    <svg viewBox="0 0 170 170">
      <defs>
        <radialGradient id="moon" cx="38%" cy="32%" r="85%">
          <stop offset="0" stop-color="#f6f4f9"/><stop offset=".6" stop-color="#e4e1ee"/><stop offset="1" stop-color="#c9c5da"/>
        </radialGradient>
        <radialGradient id="lunabody" cx="38%" cy="30%" r="85%">
          <stop offset="0" stop-color="#ffffff"/><stop offset=".6" stop-color="#f4f1ec"/><stop offset="1" stop-color="#ddd6cc"/>
        </radialGradient>
        <radialGradient id="lunaeye" cx="38%" cy="32%" r="80%">
          <stop offset="0" stop-color="#ffd9a8"/><stop offset="1" stop-color="#f0a04c"/>
        </radialGradient>
      </defs>
      <circle cx="85" cy="85" r="44" fill="url(#moon)"/>
      <g fill="#c9c5da" opacity=".55">
        <circle cx="70" cy="72" r="7"/><circle cx="98" cy="94" r="9"/>
        <circle cx="88" cy="64" r="4"/><circle cx="72" cy="102" r="5"/>
      </g>
      <g fill="#c9c5da">
        <circle cx="22" cy="38" r="2"/><circle cx="148" cy="52" r="1.6"/><circle cx="136" cy="140" r="2"/>
      </g>
      <g class="orbit">
        <g transform="translate(0,-71)">
          <g class="orbit-counter">
            <g transform="translate(85,14)">
              <ellipse cx="0" cy="0" rx="15" ry="13" fill="url(#lunabody)"/>
              <ellipse cx="-4" cy="-4" rx="6" ry="3.4" fill="#ffffff" opacity=".8" transform="rotate(-20)"/>
              <g class="luna-eyes">
                <circle cx="-4.5" cy="-1" r="2.6" fill="url(#lunaeye)"/>
                <circle cx="4.5" cy="-1" r="2.6" fill="url(#lunaeye)"/>
                <circle cx="-5.3" cy="-2" r="1" fill="#fff"/>
                <circle cx="3.7" cy="-2" r="1" fill="#fff"/>
              </g>
              <path d="M-2 3.5 Q0 5.5 2 3.5" stroke="#b3541e" stroke-width="1.2" fill="none" stroke-linecap="round"/>
              <path d="M-13 -8 L-18 -14 L-10 -11 Z" fill="#ff6f61"/>
            </g>
          </g>
        </g>
      </g>
    </svg>
  </div>

  <h1>Building software for the <span class="grad">22nd&nbsp;century</span>.</h1>

  <p class="sub">Nevarro is a boutique software consulting and micro-SaaS studio. We design, build, and run focused products for teams that value craft.</p>

  <p class="support">Need a hand with one of our products? Write to <a href="mailto:support@nevarrotech.com">support@nevarrotech.com</a></p>

  <!-- NEV -->
  <div class="stage" aria-hidden="true">
    <svg viewBox="0 0 300 290">
      <defs>
        <radialGradient id="body" cx="38%" cy="30%" r="85%">
          <stop offset="0" stop-color="#ffffff"/><stop offset=".55" stop-color="#f4f1ec"/><stop offset="1" stop-color="#ddd6cc"/>
        </radialGradient>
        <radialGradient id="belly" cx="40%" cy="35%" r="80%">
          <stop offset="0" stop-color="#ffffff"/><stop offset="1" stop-color="#ece7df"/>
        </radialGradient>
        <radialGradient id="screen" cx="42%" cy="32%" r="90%">
          <stop offset="0" stop-color="#3a4254"/><stop offset="1" stop-color="#20242f"/>
        </radialGradient>
        <radialGradient id="eye" cx="38%" cy="32%" r="80%">
          <stop offset="0" stop-color="#9ff2ff"/><stop offset=".6" stop-color="#4cd7f0"/><stop offset="1" stop-color="#2ab5d6"/>
        </radialGradient>
        <radialGradient id="coralg" cx="38%" cy="30%" r="85%">
          <stop offset="0" stop-color="#ff9c92"/><stop offset="1" stop-color="#f05a4d"/>
        </radialGradient>
        <linearGradient id="sheen" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#ffffff" stop-opacity=".85"/><stop offset="1" stop-color="#ffffff" stop-opacity="0"/>
        </linearGradient>
      </defs>

      <ellipse class="shadow" cx="150" cy="262" rx="74" ry="12" fill="#1d1d1f"/>

      <g class="bot">
        <line x1="150" y1="52" x2="150" y2="30" stroke="#c9c2b6" stroke-width="5" stroke-linecap="round"/>
        <circle class="ant-light" cx="150" cy="24" r="9" fill="url(#coralg)"/>
        <ellipse cx="146.5" cy="20.5" rx="3.2" ry="2.4" fill="#ffffff" opacity=".85"/>

        <g>
          <path d="M96 168 Q76 178 72 196" stroke="#ddd6cc" stroke-width="16" stroke-linecap="round" fill="none"/>
          <circle cx="71" cy="198" r="11" fill="url(#body)"/>
        </g>
        <g class="arm-r">
          <path d="M204 168 Q224 178 228 196" stroke="#ddd6cc" stroke-width="16" stroke-linecap="round" fill="none"/>
          <circle cx="229" cy="198" r="11" fill="url(#body)"/>
        </g>

        <rect x="88" y="52" width="124" height="164" rx="58" fill="url(#body)"/>
        <ellipse cx="122" cy="84" rx="26" ry="14" fill="url(#sheen)" transform="rotate(-24 122 84)"/>

        <rect x="104" y="86" width="92" height="76" rx="34" fill="url(#screen)"/>
        <path d="M112 104 Q150 84 188 104 L188 96 Q150 78 112 96 Z" fill="#ffffff" opacity=".10"/>

        <g class="eyes">
          <ellipse cx="132" cy="126" rx="12" ry="15" fill="url(#eye)"/>
          <ellipse cx="168" cy="126" rx="12" ry="15" fill="url(#eye)"/>
          <circle cx="128" cy="120" r="3.6" fill="#ffffff" opacity=".95"/>
          <circle cx="164" cy="120" r="3.6" fill="#ffffff" opacity=".95"/>
        </g>

        <ellipse cx="116" cy="148" rx="6" ry="3.6" fill="#ff8a80" opacity=".35"/>
        <ellipse cx="184" cy="148" rx="6" ry="3.6" fill="#ff8a80" opacity=".35"/>

        <circle cx="150" cy="190" r="15" fill="url(#belly)" stroke="#e2dbd0" stroke-width="1.5"/>
        <path d="M144 196 L144 184 L150 191 L156 184 L156 196" stroke="#f05a4d" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>

        <ellipse cx="126" cy="220" rx="15" ry="9" fill="#ddd6cc"/>
        <ellipse cx="174" cy="220" rx="15" ry="9" fill="#ddd6cc"/>
      </g>
    </svg>
  </div>
</main>

<footer>
  <!-- PIP — sitting on the footer rule -->
  <div class="perch" aria-hidden="true">
    <svg viewBox="0 0 56 48">
      <defs>
        <radialGradient id="pipbody" cx="38%" cy="30%" r="85%">
          <stop offset="0" stop-color="#fff"/><stop offset=".6" stop-color="#eef1f6"/><stop offset="1" stop-color="#d3d9e4"/>
        </radialGradient>
      </defs>
      <g class="leg-l"><path d="M20 38 L20 46" stroke="#d3d9e4" stroke-width="5" stroke-linecap="round"/></g>
      <g class="leg-r"><path d="M36 38 L36 46" stroke="#d3d9e4" stroke-width="5" stroke-linecap="round"/></g>
      <rect x="8" y="6" width="40" height="34" rx="17" fill="url(#pipbody)"/>
      <ellipse cx="20" cy="14" rx="8" ry="4.5" fill="#ffffff" opacity=".8" transform="rotate(-18 20 14)"/>
      <g class="perch-eyes">
        <circle cx="21" cy="23" r="3.4" fill="#5e8bff"/>
        <circle cx="35" cy="23" r="3.4" fill="#5e8bff"/>
        <circle cx="20" cy="22" r="1.2" fill="#fff"/>
        <circle cx="34" cy="22" r="1.2" fill="#fff"/>
      </g>
      <path d="M25 30 Q28 32.5 31 30" stroke="#8b98ab" stroke-width="1.6" fill="none" stroke-linecap="round"/>
      <line x1="28" y1="6" x2="28" y2="1" stroke="#c9c2b6" stroke-width="2.5" stroke-linecap="round"/>
      <circle cx="28" cy="0" r="2.4" fill="#b06bff"/>
    </svg>
  </div>

  <span>© 2026 Nevarro Technologies</span>
  <a href="mailto:support@nevarrotech.com">support@nevarrotech.com</a>
</footer>

</body>
</html>
