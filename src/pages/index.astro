<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Nevarro Technologies — Boutique AI Software & Research Products</title>
<meta name="description" content="Nevarro Technologies builds boutique AI software for niche industries, and publishes digital research products — reports, audits, and ebooks — for consumers.">
<style>
  :root{
    --bg:#fbfbfd; --text:#1d1d1f; --muted:#6e6e73; --faint:#a1a1a6;
    --hairline:#e8e8ed; --accent-a:#5e8bff; --accent-b:#b06bff;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    background:var(--bg); color:var(--text);
    font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","SF Pro Text","Helvetica Neue",Inter,Arial,sans-serif;
    -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility; overflow-x:hidden;
  }
  nav{position:sticky;top:0;background:rgba(251,251,253,.85);backdrop-filter:blur(12px);z-index:10;
    display:flex;align-items:center;justify-content:space-between;
    padding:1.2rem clamp(1.5rem,5vw,4rem)}
  .wordmark{font-size:.95rem;font-weight:600;letter-spacing:.14em}
  nav .links{display:flex;gap:1.6rem}
  nav a{font-size:.85rem;color:var(--muted);text-decoration:none;transition:color .25s ease}
  nav a:hover{color:var(--text)}

  .hero{min-height:calc(100svh - 62px);display:flex;flex-direction:column;align-items:center;justify-content:center;
    text-align:center;padding:2rem 1.5rem 3rem}
  h1{font-size:clamp(2.4rem,7vw,5rem);font-weight:700;letter-spacing:-.025em;line-height:1.05;max-width:16ch}
  h1 .grad{background:linear-gradient(92deg,var(--accent-a),var(--accent-b));-webkit-background-clip:text;background-clip:text;color:transparent}
  .sub{margin-top:1.2rem;font-size:clamp(1.02rem,2.2vw,1.28rem);color:var(--muted);letter-spacing:-.01em;max-width:60ch;line-height:1.6}
  .supportline{margin-top:.9rem;font-size:clamp(.95rem,2vw,1.05rem);color:var(--muted)}
  .supportline a{color:var(--accent-a);text-decoration:none;font-weight:500}
  .supportline a:hover{opacity:.7}

  .troupe{margin-top:clamp(1.5rem,4vh,3rem);display:flex;align-items:flex-end;justify-content:center;gap:clamp(.5rem,3vw,2.5rem)}
  .troupe svg{height:100%;width:auto;overflow:visible}
  .nev-wrap{height:min(220px,30vh)}
  .buddy{height:min(90px,13vh)}
  .buddy.left{margin-bottom:.5rem}
  .buddy.right{margin-bottom:1.2rem}

  .bot{animation:bob 4.5s ease-in-out infinite}
  @keyframes bob{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
  .shadow{transform-origin:150px 262px;animation:shadowbob 4.5s ease-in-out infinite}
  @keyframes shadowbob{0%,100%{transform:scaleX(1);opacity:.16}50%{transform:scaleX(.82);opacity:.09}}
  .eyes{transform-origin:150px 128px;animation:blink 5.2s ease-in-out infinite}
  @keyframes blink{0%,46%,50%,100%{transform:scaleY(1)}48%{transform:scaleY(.06)}}
  .arm-r{transform-origin:206px 168px;animation:wave 7s ease-in-out infinite}
  @keyframes wave{0%,78%,100%{transform:rotate(0)}84%{transform:rotate(-42deg)}90%{transform:rotate(-14deg)}95%{transform:rotate(-38deg)}}
  .ant-light{animation:antpulse 3s ease-in-out infinite}
  @keyframes antpulse{0%,100%{opacity:1}50%{opacity:.4}}
  .hop-a{animation:hop 3.2s ease-in-out infinite}
  .hop-b{animation:hop 3.8s ease-in-out infinite;animation-delay:.5s}
  @keyframes hop{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
  .bshadow-a{transform-origin:center;animation:bshadow 3.2s ease-in-out infinite}
  .bshadow-b{transform-origin:center;animation:bshadow 3.8s ease-in-out infinite;animation-delay:.5s}
  @keyframes bshadow{0%,100%{opacity:.14;transform:scaleX(1)}50%{opacity:.08;transform:scaleX(.82)}}
  .blink-a{transform-origin:center;animation:blink 4.4s ease-in-out infinite}
  .blink-b{transform-origin:center;animation:blink 5.6s ease-in-out infinite;animation-delay:1s}

  section{max-width:1000px;margin:0 auto;padding:4.5rem 1.5rem}
  .sec-kicker{font-size:.78rem;font-weight:600;letter-spacing:.2em;color:var(--accent-a);text-transform:uppercase;text-align:center}
  h2{font-size:clamp(1.8rem,4.5vw,2.6rem);font-weight:700;letter-spacing:-.02em;text-align:center;margin-top:.6rem}
  .sec-sub{color:var(--muted);text-align:center;max-width:56ch;margin:1rem auto 0;line-height:1.6}

  .offer{background:#fff;border:1px solid var(--hairline);border-radius:24px;padding:clamp(1.8rem,4vw,2.8rem);
    margin-top:2.4rem;box-shadow:0 1px 2px rgba(0,0,0,.03)}
  .offer .tag{display:inline-block;font-size:.72rem;font-weight:600;letter-spacing:.16em;text-transform:uppercase;
    color:var(--accent-a);background:#eef3ff;border-radius:999px;padding:.35rem .85rem}
  .offer.consumer .tag{color:var(--accent-b);background:#f5eeff}
  .offer h3{font-size:clamp(1.3rem,3vw,1.7rem);font-weight:700;letter-spacing:-.015em;margin-top:1rem}
  .offer p{color:var(--muted);line-height:1.7;margin-top:.8rem;max-width:64ch}
  .offer ul{list-style:none;color:var(--muted);line-height:2;margin-top:.8rem;font-size:.95rem}
  .offer ul li::before{content:"—";color:var(--accent-a);margin-right:.6rem}
  .offer.consumer ul li::before{color:var(--accent-b)}
  .pricenote{margin-top:1.2rem;padding:1rem 1.2rem;background:var(--bg);border:1px solid var(--hairline);border-radius:14px;
    color:var(--text);font-size:.95rem;line-height:1.6}
  .pricenote span{color:var(--muted)}
  .offer .cta{margin-top:1.4rem}
  .offer .cta a{font-weight:500;color:var(--accent-a);text-decoration:none}
  .offer.consumer .cta a{color:var(--accent-b)}
  .offer .cta a:hover{opacity:.7}

  .contactband{text-align:center;border-top:1px solid var(--hairline)}
  .contactband p{color:var(--muted);line-height:1.7;max-width:52ch;margin:1rem auto 0}
  .contactband a{color:var(--accent-a);text-decoration:none;font-weight:500}

  footer{border-top:1px solid var(--hairline);display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;
    font-size:.78rem;color:var(--faint);padding:1.2rem clamp(1.5rem,5vw,4rem)}
  footer .pol{display:flex;gap:1.2rem;flex-wrap:wrap}
  footer a{color:var(--muted);text-decoration:none;transition:color .25s}
  footer a:hover{color:var(--text)}
  .made{color:var(--muted)}
  @media (max-width:700px){footer{justify-content:center;text-align:center}}
  @media (prefers-reduced-motion: reduce){
    .bot,.shadow,.eyes,.arm-r,.ant-light,.hop-a,.hop-b,.bshadow-a,.bshadow-b,.blink-a,.blink-b{animation:none}
    html{scroll-behavior:auto}
  }
</style>
</head>
<body>

